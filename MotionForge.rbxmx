	currentMove.Cutscene.Enabled = not currentMove.Cutscene.Enabled
	enableToggle.Text = currentMove.Cutscene.Enabled and "✅ Cutscene Effects: ON" or "⬜ Cutscene Effects: OFF"
	enableToggle.BackgroundColor3 = currentMove.Cutscene.Enabled and Color3.fromRGB(0, 120, 215) or Color3.fromRGB(80, 80, 90)
	if statusText then
		statusText.Text = currentMove.Cutscene.Enabled and "Cutscene enabled" or "Cutscene disabled"
		task.wait(1)
		if updateStatusFunc then updateStatusFunc() end
	end
end)

