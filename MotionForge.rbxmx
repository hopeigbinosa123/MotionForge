local damageRow, damageInputTemp = createRow(combatCard, "Damage", currentMove.Damage, function(val)
	currentMove.Damage = val
	if updateStatusFunc then updateStatusFunc() end
	if visualizerActive and type(updateHitboxVisualizer) == "function" then
		updateHitboxVisualizer()
	end
end, 40)
damageInput = damageInputTemp

local knockbackRow, knockbackInputTemp = createRow(combatCard, "Knockback", currentMove.Knockback, function(val)
	currentMove.Knockback = val
	if visualizerActive and type(updateHitboxVisualizer) == "function" then
		updateHitboxVisualizer()
	end
end, 80)
knockbackInput = knockbackInputTemp

-- ========== CARD 4: TIMELINE EDITOR (with Animation Preview) ==========
local timelineCard = createCard("⏱️ Timeline", 4)

local eventListFrame = Instance.new("ScrollingFrame")
eventListFrame.Size = UDim2.new(1, 0, 0, 150)
eventListFrame.Position = UDim2.new(0, 0, 0, 40)
eventListFrame.BackgroundColor3 = Color3.fromRGB(40, 40, 45)
eventListFrame.BorderSizePixel = 0
eventListFrame.ScrollBarThickness = 6
eventListFrame.Parent = timelineCard

local eventListCorner = Instance.new("UICorner")
eventListCorner.CornerRadius = UDim.new(0, 8)
eventListCorner.Parent = eventListFrame

local eventListLayout = Instance.new("UIListLayout")
eventListLayout.Padding = UDim.new(0, 4)
eventListLayout.SortOrder = Enum.SortOrder.LayoutOrder
eventListLayout.Parent = eventListFrame

function refreshEventListFunc()
	for _, child in ipairs(eventListFrame:GetChildren()) do
		if child:IsA("TextButton") or child:IsA("Frame") or child:IsA("TextLabel") then
			child:Destroy()
		end
	end

	if #currentMove.Timeline == 0 then
		local emptyLabel = Instance.new("TextLabel")
		emptyLabel.Text = "No events. Click '+ Add Event' to create one."
		emptyLabel.TextColor3 = Color3.fromRGB(100, 100, 110)
		emptyLabel.TextSize = 11
		emptyLabel.BackgroundTransparency = 1
		emptyLabel.Size = UDim2.new(1, 0, 0, 40)
		emptyLabel.Parent = eventListFrame
	else
		for i, event in ipairs(currentMove.Timeline) do
			local row = Instance.new("Frame")
			row.Name = "EventRow_" .. i
			row.BackgroundColor3 = Color3.fromRGB(50, 50, 55)
			row.BorderSizePixel = 0
			row.Size = UDim2.new(1, -10, 0, 36)
			row.Parent = eventListFrame

			local rowCorner = Instance.new("UICorner")
			rowCorner.CornerRadius = UDim.new(0, 6)
			rowCorner.Parent = row

			local eventLabel = Instance.new("TextLabel")
			eventLabel.Text = formatEventText(event)
			eventLabel.TextColor3 = Color3.fromRGB(200, 200, 200)
			eventLabel.TextSize = 11
			eventLabel.Font = Enum.Font.Gotham
			eventLabel.TextXAlignment = Enum.TextXAlignment.Left
			eventLabel.BackgroundTransparency = 1
			eventLabel.Size = UDim2.new(1, -80, 1, 0)
			eventLabel.Position = UDim2.new(0, 8, 0, 0)
			eventLabel.Parent = row

			local editButton = Instance.new("TextButton")
			editButton.Text = "✏️"
			editButton.TextColor3 = Color3.fromRGB(255, 255, 255)
			editButton.TextSize = 14
			editButton.BackgroundColor3 = Color3.fromRGB(70, 70, 80)
			editButton.BorderSizePixel = 0
			editButton.Size = UDim2.new(0, 30, 0, 28)
			editButton.Position = UDim2.new(1, -65, 0, 4)
			editButton.Parent = row

			local editCorner = Instance.new("UICorner")
			editCorner.CornerRadius = UDim.new(0, 6)
			editCorner.Parent = editButton

			local delButton = Instance.new("TextButton")
			delButton.Text = "🗑️"
			delButton.TextColor3 = Color3.fromRGB(255, 255, 255)
			delButton.TextSize = 12
			delButton.BackgroundColor3 = Color3.fromRGB(180, 50, 50)
			delButton.BorderSizePixel = 0
			delButton.Size = UDim2.new(0, 30, 0, 28)
			delButton.Position = UDim2.new(1, -32, 0, 4)
			delButton.Parent = row

			local delCorner = Instance.new("UICorner")
			delCorner.CornerRadius = UDim.new(0, 6)
			delCorner.Parent = delButton

			editButton.MouseButton1Click:Connect(function()
				local dialog = Instance.new("Frame")
				dialog.Size = UDim2.new(0, 300, 0, 200)
				dialog.Position = UDim2.new(0.5, -150, 0.5, -100)
				dialog.BackgroundColor3 = Color3.fromRGB(35, 35, 40)
				dialog.BorderSizePixel = 0
				dialog.Parent = mainGui

				local dialogCorner = Instance.new("UICorner")
				dialogCorner.CornerRadius = UDim.new(0, 10)
				dialogCorner.Parent = dialog

				local title = Instance.new("TextLabel")
				title.Text = "Edit " .. event.type .. " Event"
				title.TextColor3 = Color3.fromRGB(255, 255, 255)
				title.TextSize = 14
				title.Font = Enum.Font.GothamSemibold
				title.BackgroundTransparency = 1
				title.Size = UDim2.new(1, 0, 0, 40)
				title.Parent = dialog

				local timeLabel = Instance.new("TextLabel")
				timeLabel.Text = "Time (seconds):"
				timeLabel.TextColor3 = Color3.fromRGB(160, 160, 170)
				timeLabel.TextSize = 11
				timeLabel.BackgroundTransparency = 1
				timeLabel.Size = UDim2.new(0, 100, 0, 30)
				timeLabel.Position = UDim2.new(0, 15, 0, 50)
				timeLabel.Parent = dialog

				local timeBox = Instance.new("TextBox")
				timeBox.Text = string.format("%.2f", event.time)
				timeBox.TextColor3 = Color3.fromRGB(255, 255, 255)
				timeBox.TextSize = 12
				timeBox.BackgroundColor3 = Color3.fromRGB(50, 50, 55)
				timeBox.BorderSizePixel = 0
				timeBox.Size = UDim2.new(0, 100, 0, 30)
				timeBox.Position = UDim2.new(0, 120, 0, 50)
				timeBox.Parent = dialog

				local timeCorner = Instance.new("UICorner")
				timeCorner.CornerRadius = UDim.new(0, 6)
				timeCorner.Parent = timeBox

				local paramLabel = nil
				local paramBox = nil

				if event.type == "Hitbox" then
					paramLabel = Instance.new("TextLabel")
					paramLabel.Text = "Damage:"
					paramLabel.TextColor3 = Color3.fromRGB(160, 160, 170)
					paramLabel.TextSize = 11
					paramLabel.BackgroundTransparency = 1
					paramLabel.Size = UDim2.new(0, 100, 0, 30)
					paramLabel.Position = UDim2.new(0, 15, 0, 90)
					paramLabel.Parent = dialog

					paramBox = Instance.new("TextBox")
					paramBox.Text = event.data.damage or "15"
					paramBox.TextColor3 = Color3.fromRGB(255, 255, 255)
					paramBox.TextSize = 12
					paramBox.BackgroundColor3 = Color3.fromRGB(50, 50, 55)
					paramBox.BorderSizePixel = 0
					paramBox.Size = UDim2.new(0, 100, 0, 30)
					paramBox.Position = UDim2.new(0, 120, 0, 90)
					paramBox.Parent = dialog

					local paramCorner = Instance.new("UICorner")
					paramCorner.CornerRadius = UDim.new(0, 6)
					paramCorner.Parent = paramBox

				elseif event.type == "Sound" then
					paramLabel = Instance.new("TextLabel")
					paramLabel.Text = "Sound ID:"
					paramLabel.TextColor3 = Color3.fromRGB(160, 160, 170)
					paramLabel.TextSize = 11
					paramLabel.BackgroundTransparency = 1
					paramLabel.Size = UDim2.new(0, 100, 0, 30)
					paramLabel.Position = UDim2.new(0, 15, 0, 90)
					paramLabel.Parent = dialog

					paramBox = Instance.new("TextBox")
					paramBox.Text = event.data.soundId or "rbxassetid://123456789"
					paramBox.TextColor3 = Color3.fromRGB(255, 255, 255)
					paramBox.TextSize = 11
					paramBox.BackgroundColor3 = Color3.fromRGB(50, 50, 55)
					paramBox.BorderSizePixel = 0
					paramBox.Size = UDim2.new(0, 150, 0, 30)
					paramBox.Position = UDim2.new(0, 120, 0, 90)
					paramBox.Parent = dialog

					local paramCorner = Instance.new("UICorner")
					paramCorner.CornerRadius = UDim.new(0, 6)
					paramCorner.Parent = paramBox

				elseif event.type == "Effect" then
					paramLabel = Instance.new("TextLabel")
					paramLabel.Text = "Effect Type:"
					paramLabel.TextColor3 = Color3.fromRGB(160, 160, 170)
					paramLabel.TextSize = 11
					paramLabel.BackgroundTransparency = 1
					paramLabel.Size = UDim2.new(0, 100, 0, 30)
					paramLabel.Position = UDim2.new(0, 15, 0, 90)
					paramLabel.Parent = dialog

					paramBox = Instance.new("TextBox")
					paramBox.Text = event.data.effectType or "Basic Explosion"
					paramBox.TextColor3 = Color3.fromRGB(255, 255, 255)
					paramBox.TextSize = 12
					paramBox.BackgroundColor3 = Color3.fromRGB(50, 50, 55)
					paramBox.BorderSizePixel = 0
					paramBox.Size = UDim2.new(0, 150, 0, 30)
					paramBox.Position = UDim2.new(0, 120, 0, 90)
					paramBox.Parent = dialog

					local paramCorner = Instance.new("UICorner")
					paramCorner.CornerRadius = UDim.new(0, 6)
					paramCorner.Parent = paramBox
				end

				local saveEditBtn = Instance.new("TextButton")
				saveEditBtn.Text = "Save Changes"
				saveEditBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
				saveEditBtn.TextSize = 12
				saveEditBtn.BackgroundColor3 = Color3.fromRGB(0, 120, 215)
				saveEditBtn.BorderSizePixel = 0
				saveEditBtn.Size = UDim2.new(0, 120, 0, 36)
				saveEditBtn.Position = UDim2.new(0, 15, 0, 140)
				saveEditBtn.Parent = dialog

				local saveCorner = Instance.new("UICorner")
				saveCorner.CornerRadius = UDim.new(0, 6)
				saveCorner.Parent = saveEditBtn

				local cancelBtn = Instance.new("TextButton")
				cancelBtn.Text = "Cancel"
				cancelBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
				cancelBtn.TextSize = 12
				cancelBtn.BackgroundColor3 = Color3.fromRGB(80, 80, 90)
				cancelBtn.BorderSizePixel = 0
				cancelBtn.Size = UDim2.new(0, 120, 0, 36)
				cancelBtn.Position = UDim2.new(0, 150, 0, 140)
				cancelBtn.Parent = dialog

				local cancelCorner = Instance.new("UICorner")
				cancelCorner.CornerRadius = UDim.new(0, 6)
				cancelCorner.Parent = cancelBtn

				local function closeDialog()
					dialog:Destroy()
				end

				saveEditBtn.MouseButton1Click:Connect(function()
					local newTime = tonumber(timeBox.Text)
					if not newTime then newTime = event.time end

					local newData = {}
					if event.type == "Hitbox" then
						newData = {
							damage = paramBox.Text,
							knockback = event.data.knockback or "500"
						}
					elseif event.type == "Sound" then
						newData = {soundId = paramBox.Text}
					elseif event.type == "Effect" then
						newData = {effectType = paramBox.Text}
					end

					updateEvent(i, newTime, newData)
					refreshEventListFunc()
					if updateStatusFunc then updateStatusFunc() end
					if statusText then
						statusText.Text = "Event updated"
						task.wait(1)
						if updateStatusFunc then updateStatusFunc() end
					end
					closeDialog()
				end)

				cancelBtn.MouseButton1Click:Connect(closeDialog)
			end)

			delButton.MouseButton1Click:Connect(function()
				removeEvent(i)
				refreshEventListFunc()
				if updateStatusFunc then updateStatusFunc() end
				if visualizerActive and type(updateHitboxVisualizer) == "function" then
					updateHitboxVisualizer()
				end
				if statusText then
					statusText.Text = "Event deleted"
					task.wait(1)
					if updateStatusFunc then updateStatusFunc() end
				end
			end)
		end
	end

	task.defer(function()
		eventListFrame.CanvasSize = UDim2.new(0, 0, 0, eventListLayout.AbsoluteContentSize.Y + 10)
	end)
end

