-- Custom templates saved by user
local customTemplates = {}

-- Load custom templates from plugin storage
local function loadCustomTemplates()
	local templateData = plugin:GetSetting("MotionForge_CustomTemplates")
	if templateData and templateData ~= "" then
		local success, decoded = pcall(function()
			return game:GetService("HttpService"):JSONDecode(templateData)
		end)
		if success and decoded then
			for _, template in ipairs(decoded) do
				table.insert(customTemplates, template)
			end
		end
	end
end

-- Save custom templates to plugin storage
local function saveCustomTemplates()
	local success = pcall(function()
		plugin:SetSetting("MotionForge_CustomTemplates", game:GetService("HttpService"):JSONEncode(customTemplates))
	end)
	return success
end

-- Add a custom template
local function addCustomTemplate(name, description, icon)
	local template = {
		Name = name,
		Description = description or "Custom move template",
		Icon = icon or "⭐",
		IsCustom = true,
		Data = {
			Name = currentMove.Name,
			Cooldown = currentMove.Cooldown,
			AnimId = currentMove.AnimId,
			Damage = currentMove.Damage,
			Knockback = currentMove.Knockback,
			Timeline = currentMove.Timeline,
			Cutscene = currentMove.Cutscene
		}
	}
	table.insert(customTemplates, template)
	saveCustomTemplates()
	return true
end

-- Remove a custom template
local function removeCustomTemplate(index)
	table.remove(customTemplates, index)
	saveCustomTemplates()
end

-- Load a template into current move
local function loadTemplate(template)
	currentMove.Name = template.Data.Name
	currentMove.Cooldown = template.Data.Cooldown
	currentMove.AnimId = template.Data.AnimId
	currentMove.Damage = template.Data.Damage
	currentMove.Knockback = template.Data.Knockback
	currentMove.Timeline = template.Data.Timeline
	currentMove.Cutscene = template.Data.Cutscene

	if nameInput then nameInput.Text = currentMove.Name end
	if cooldownInput then cooldownInput.Text = currentMove.Cooldown end
	if animInput then animInput.Text = currentMove.AnimId end
	if damageInput then damageInput.Text = currentMove.Damage end
	if knockbackInput then knockbackInput.Text = currentMove.Knockback end

	mainGui.Title = "MotionForge - " .. currentMove.Name
	if refreshEventListFunc then refreshEventListFunc() end
	if updateStatusFunc then updateStatusFunc() end
	if visualizerActive and type(updateHitboxVisualizer) == "function" then
		updateHitboxVisualizer()
	end
end

loadCustomTemplates()

