local templateListFrame = Instance.new("ScrollingFrame")
templateListFrame.Size = UDim2.new(1, 0, 0, 200)
templateListFrame.Position = UDim2.new(0, 0, 0, 85)
templateListFrame.BackgroundColor3 = Color3.fromRGB(40, 40, 45)
templateListFrame.BorderSizePixel = 0
templateListFrame.ScrollBarThickness = 6
templateListFrame.Parent = templateCard

local templateListCorner = Instance.new("UICorner")
templateListCorner.CornerRadius = UDim.new(0, 8)
templateListCorner.Parent = templateListFrame

local templateListLayout = Instance.new("UIListLayout")
templateListLayout.Padding = UDim.new(0, 4)
templateListLayout.SortOrder = Enum.SortOrder.LayoutOrder
templateListLayout.Parent = templateListFrame

local function refreshTemplateList(searchTerm)
	for _, child in ipairs(templateListFrame:GetChildren()) do
		if child:IsA("TextButton") or child:IsA("Frame") then
			child:Destroy()
		end
	end

	local allTemplates = {}
	for _, t in ipairs(builtInTemplates) do
		table.insert(allTemplates, t)
	end
	for _, t in ipairs(customTemplates) do
		table.insert(allTemplates, t)
	end

	local filteredTemplates = allTemplates
	if searchTerm and searchTerm ~= "" then
		filteredTemplates = {}
		local lowerSearch = string.lower(searchTerm)
		for _, t in ipairs(allTemplates) do
			if string.find(string.lower(t.Name), lowerSearch) or string.find(string.lower(t.Description), lowerSearch) then
				table.insert(filteredTemplates, t)
			end
		end
	end

	if #filteredTemplates == 0 then
		local emptyLabel = Instance.new("TextLabel")
		emptyLabel.Text = "No templates found"
		emptyLabel.TextColor3 = Color3.fromRGB(100, 100, 110)
		emptyLabel.TextSize = 12
		emptyLabel.BackgroundTransparency = 1
		emptyLabel.Size = UDim2.new(1, 0, 0, 40)
		emptyLabel.Parent = templateListFrame
	else
		for i, template in ipairs(filteredTemplates) do
			local row = Instance.new("Frame")
			row.BackgroundColor3 = Color3.fromRGB(50, 50, 55)
			row.BorderSizePixel = 0
			row.Size = UDim2.new(1, -10, 0, 70)
			row.Parent = templateListFrame

			local rowCorner = Instance.new("UICorner")
			rowCorner.CornerRadius = UDim.new(0, 8)
			rowCorner.Parent = row

			local iconLabel = Instance.new("TextLabel")
			iconLabel.Text = template.Icon or "📦"
			iconLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
			iconLabel.TextSize = 24
			iconLabel.BackgroundTransparency = 1
			iconLabel.Size = UDim2.new(0, 50, 1, 0)
			iconLabel.Parent = row

			local nameLabel = Instance.new("TextLabel")
			nameLabel.Text = template.Name
			nameLabel.TextColor3 = Color3.fromRGB(220, 220, 230)
			nameLabel.TextSize = 13
			nameLabel.Font = Enum.Font.GothamSemibold
			nameLabel.TextXAlignment = Enum.TextXAlignment.Left
			nameLabel.BackgroundTransparency = 1
			nameLabel.Size = UDim2.new(1, -110, 0, 25)
			nameLabel.Position = UDim2.new(0, 55, 0, 5)
			nameLabel.Parent = row

			local descLabel = Instance.new("TextLabel")
			descLabel.Text = template.Description
			descLabel.TextColor3 = Color3.fromRGB(140, 140, 150)
			descLabel.TextSize = 10
			descLabel.Font = Enum.Font.Gotham
			descLabel.TextXAlignment = Enum.TextXAlignment.Left
			descLabel.TextWrapped = true
			descLabel.BackgroundTransparency = 1
			descLabel.Size = UDim2.new(1, -110, 0, 30)
			descLabel.Position = UDim2.new(0, 55, 0, 30)
			descLabel.Parent = row

			local loadBtn = Instance.new("TextButton")
			loadBtn.Text = "Load"
			loadBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
			loadBtn.TextSize = 11
			loadBtn.Font = Enum.Font.GothamSemibold
			loadBtn.BackgroundColor3 = Color3.fromRGB(0, 120, 215)
			loadBtn.BorderSizePixel = 0
			loadBtn.Size = UDim2.new(0, 50, 0, 25)
			loadBtn.Position = UDim2.new(1, -60, 0, 40)
			loadBtn.Parent = row

			local loadCorner = Instance.new("UICorner")
			loadCorner.CornerRadius = UDim.new(0, 6)
			loadCorner.Parent = loadBtn

			loadBtn.MouseButton1Click:Connect(function()
				loadTemplate(template)
				if statusText then
					statusText.Text = "Loaded template: " .. template.Name
					task.wait(1.5)
					if updateStatusFunc then updateStatusFunc() end
				end
			end)

			if template.IsCustom then
				local deleteBtn = Instance.new("TextButton")
				deleteBtn.Text = "🗑️"
				deleteBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
				deleteBtn.TextSize = 12
				deleteBtn.BackgroundColor3 = Color3.fromRGB(180, 50, 50)
				deleteBtn.BorderSizePixel = 0
				deleteBtn.Size = UDim2.new(0, 30, 0, 25)
				deleteBtn.Position = UDim2.new(1, -100, 0, 40)
				deleteBtn.Parent = row

				local deleteCorner = Instance.new("UICorner")
				deleteCorner.CornerRadius = UDim.new(0, 6)
				deleteCorner.Parent = deleteBtn

				local customIndex = nil
				for idx, ct in ipairs(customTemplates) do
					if ct.Name == template.Name then
						customIndex = idx
						break
					end
				end

				deleteBtn.MouseButton1Click:Connect(function()
					if customIndex then
						removeCustomTemplate(customIndex)
						refreshTemplateList(searchBox.Text)
						if statusText then
							statusText.Text = "Deleted template: " .. template.Name
							task.wait(1.5)
							if updateStatusFunc then updateStatusFunc() end
						end
					end
				end)
			end
		end
	end

	task.defer(function()
		templateListFrame.CanvasSize = UDim2.new(0, 0, 0, templateListLayout.AbsoluteContentSize.Y + 10)
	end)
end

searchBox.Changed:Connect(function(prop)
	if prop == "Text" then
		refreshTemplateList(searchBox.Text)
	end
end)

