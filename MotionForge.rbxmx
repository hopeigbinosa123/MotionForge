local function createCard(title, layoutOrder)
	local card = Instance.new("Frame")
	card.BackgroundColor3 = Color3.fromRGB(28, 28, 32)
	card.BorderSizePixel = 0
	card.LayoutOrder = layoutOrder
	card.Size = UDim2.new(1, -32, 0, 0)
	card.AutomaticSize = Enum.AutomaticSize.Y
	card.Parent = scrollContent

	local corner = Instance.new("UICorner")
	corner.CornerRadius = UDim.new(0, 10)
	corner.Parent = card

	local padding = Instance.new("UIPadding")
	padding.PaddingLeft = UDim.new(0, 16)
	padding.PaddingRight = UDim.new(0, 16)
	padding.PaddingTop = UDim.new(0, 12)
	padding.PaddingBottom = UDim.new(0, 12)
	padding.Parent = card

	local header = Instance.new("TextLabel")
	header.Text = title
	header.TextColor3 = Color3.fromRGB(220, 220, 230)
	header.TextSize = 14
	header.Font = Enum.Font.GothamSemibold
	header.TextXAlignment = Enum.TextXAlignment.Left
	header.BackgroundTransparency = 1
	header.Size = UDim2.new(1, 0, 0, 28)
	header.Parent = card

	return card
end

-- ========== FUNCTION: CREATE ROW ==========
local function createRow(parent, labelText, defaultValue, onChanged, yPos)
	local row = Instance.new("Frame")
	row.BackgroundTransparency = 1
	row.Size = UDim2.new(1, 0, 0, 36)
	row.Position = UDim2.new(0, 0, 0, yPos)
	row.Parent = parent

	local label = Instance.new("TextLabel")
	label.Text = labelText
	label.TextColor3 = Color3.fromRGB(160, 160, 170)
	label.TextSize = 12
	label.Font = Enum.Font.Gotham
	label.TextXAlignment = Enum.TextXAlignment.Left
	label.BackgroundTransparency = 1
	label.Size = UDim2.new(0, 100, 1, 0)
	label.Parent = row

	local input = Instance.new("TextBox")
	input.Text = defaultValue or ""
	input.TextColor3 = Color3.fromRGB(255, 255, 255)
	input.TextSize = 12
	input.Font = Enum.Font.Gotham
	input.BackgroundColor3 = Color3.fromRGB(45, 45, 50)
	input.BorderSizePixel = 0
	input.Size = UDim2.new(1, -110, 1, 0)
	input.Position = UDim2.new(0, 110, 0, 0)
	input.Parent = row

	local inputCorner = Instance.new("UICorner")
	inputCorner.CornerRadius = UDim.new(0, 6)
	inputCorner.Parent = input

	if onChanged then
		input.Changed:Connect(function(prop)
			if prop == "Text" then
				onChanged(input.Text)
			end
		end)
	end

	return row, input
end

-- ========== TIMELINE FUNCTIONS ==========
local function sortTimeline()
	table.sort(currentMove.Timeline, function(a, b)
		return a.time < b.time
	end)
end

local function addEvent(eventType, time, data)
	table.insert(currentMove.Timeline, {
		type = eventType,
		time = time,
		data = data or {}
	})
	sortTimeline()
end

local function removeEvent(index)
	table.remove(currentMove.Timeline, index)
end

local function updateEvent(index, newTime, newData)
	if currentMove.Timeline[index] then
		currentMove.Timeline[index].time = newTime
		currentMove.Timeline[index].data = newData
		sortTimeline()
		if visualizerActive and type(updateHitboxVisualizer) == "function" then
			updateHitboxVisualizer()
		end
	end
end

local function getEventIcon(eventType)
	if eventType == "Hitbox" then
		return "🔴"
	elseif eventType == "Sound" then
		return "🔊"
	elseif eventType == "Effect" then
		return "✨"
	end
	return "📌"
end

local function formatEventText(event)
	local icon = getEventIcon(event.type)
	local timeStr = string.format("%.2f", event.time)

	if event.type == "Hitbox" then
		local dmg = event.data.damage or "?"
		local knock = event.data.knockback or "?"
		return string.format("%s %ss | Hitbox | Dmg: %s, KB: %s", icon, timeStr, dmg, knock)
	elseif event.type == "Sound" then
		local soundId = event.data.soundId or "none"
		local shortId = string.sub(soundId, -8)
		return string.format("%s %ss | Sound | ID: ...%s", icon, timeStr, shortId)
	elseif event.type == "Effect" then
		local effectType = event.data.effectType or "basic"
		return string.format("%s %ss | Effect | %s", icon, timeStr, effectType)
	end
	return string.format("%s %ss | %s", icon, timeStr, event.type)
end

-- ========== HITBOX VISUALIZER FUNCTIONS ==========
local function clearPreview()
	for _, part in ipairs(currentPreviewParts) do
		if part and part.Parent then
			part:Destroy()
		end
	end
	currentPreviewParts = {}
end

local function createHitboxPreview(size, position, color, transparency)
	clearPreview()

	local previewPart = Instance.new("Part")
	previewPart.Size = Vector3.new(size, size, size)
	previewPart.Position = position
	previewPart.Anchored = true
	previewPart.CanCollide = false
	previewPart.Transparency = transparency or 0.5
	previewPart.Color = color
	previewPart.Material = Enum.Material.Neon

	local selectionBox = Instance.new("SelectionBox")
	selectionBox.Adornee = previewPart
	selectionBox.Color3 = color
	selectionBox.LineThickness = 0.05
	selectionBox.Transparency = 0.3
	selectionBox.Parent = previewPart

	previewPart.Parent = workspace.CurrentCamera or workspace
	table.insert(currentPreviewParts, previewPart)

	return previewPart
end

local function updateHitboxVisualizer()
	if not visualizerActive then
		clearPreview()
		return
	end

	local hitboxEvent = nil
	for _, event in ipairs(currentMove.Timeline) do
		if event.type == "Hitbox" then
			hitboxEvent = event
			break
		end
	end

	if hitboxEvent then
		local damage = tonumber(hitboxEvent.data.damage) or 15
		local clampedDamage = math.max(1, math.min(100, damage))
		local red = clampedDamage / 100
		local green = 1 - (clampedDamage / 100)
		local color = Color3.fromRGB(255 * red, 255 * green, 0)

		local knockback = tonumber(hitboxEvent.data.knockback) or 500
		local size = 3 + (knockback / 500)

		local camera = workspace.CurrentCamera
		if camera then
			local position = camera.CFrame.Position + camera.CFrame.LookVector * 10
			createHitboxPreview(size, position, color, 0.5)
		else
			createHitboxPreview(size, Vector3.new(0, 5, 0), color, 0.5)
		end
	else
		clearPreview()
	end
end

local function toggleVisualizer()
	visualizerActive = not visualizerActive
	if visualizerActive then
		task.delay(0.1, function()
			if type(updateHitboxVisualizer) == "function" then
				updateHitboxVisualizer()
			end
		end)
		if statusText then
			statusText.Text = "Hitbox Visualizer: ON"
			task.wait(1.5)
			if updateStatusFunc then updateStatusFunc() end
		end
	else
		clearPreview()
		if statusText then
			statusText.Text = "Hitbox Visualizer: OFF"
			task.wait(1.5)
			if updateStatusFunc then updateStatusFunc() end
		end
	end
end

-- ========== ANIMATION PREVIEW FUNCTIONS ==========

local function createPreviewDummy()
	if previewDummy and previewDummy.Parent then
		return previewDummy
	end

	if previewDummy then
		previewDummy:Destroy()
		previewDummy = nil
		previewAnimator = nil
	end

	local dummy = Instance.new("Model")
	dummy.Name = "MotionForge_Dummy"

	local rootPart = Instance.new("Part")
	rootPart.Name = "HumanoidRootPart"
	rootPart.Size = Vector3.new(2, 1, 1)
	rootPart.Shape = Enum.PartType.Block
	rootPart.Anchored = true
	rootPart.CanCollide = false
	rootPart.Transparency = 0.5
	rootPart.BrickColor = BrickColor.new("Bright blue")
	rootPart.Parent = dummy

	local camera = workspace.CurrentCamera
	if camera then
		local camPos = camera.CFrame.Position
		local lookVec = camera.CFrame.LookVector
		rootPart.Position = camPos + lookVec * 15
		rootPart.Position = rootPart.Position + Vector3.new(0, 5, 0)
	else
		rootPart.Position = Vector3.new(0, 5, 0)
	end

	local torso = Instance.new("Part")
	torso.Name = "Torso"
	torso.Size = Vector3.new(2, 1.5, 1)
	torso.Shape = Enum.PartType.Block
	torso.Anchored = true
	torso.CanCollide = false
	torso.Transparency = 0.5
	torso.BrickColor = BrickColor.new("Bright red")
	torso.Position = rootPart.Position + Vector3.new(0, 1.5, 0)
	torso.Parent = dummy

	local head = Instance.new("Part")
	head.Name = "Head"
	head.Size = Vector3.new(1.2, 1.2, 1.2)
	head.Shape = Enum.PartType.Ball
	head.Anchored = true
	head.CanCollide = false
	head.Transparency = 0.5
	head.BrickColor = BrickColor.new("Bright yellow")
	head.Position = rootPart.Position + Vector3.new(0, 3.5, 0)
	head.Parent = dummy

	local humanoid = Instance.new("Humanoid")
	humanoid.Parent = dummy

	previewAnimator = Instance.new("Animator")
	previewAnimator.Parent = humanoid

	dummy.Parent = workspace
	previewDummy = dummy

	if statusText then
		statusText.Text = "Dummy created! Load animation to preview."
		task.wait(1.5)
		if updateStatusFunc then updateStatusFunc() end
	end

	return previewDummy
end

local function destroyPreviewDummy()
	if previewDummy then
		previewDummy:Destroy()
		previewDummy = nil
		previewAnimator = nil
	end
end

local function loadAnimationOnDummy(animationId)
	if not previewDummy then
		createPreviewDummy()
		if not previewAnimator then return end
	end

	if not animationId or animationId == "" then
		if statusText then
			statusText.Text = "No animation ID set"
			task.wait(1.5)
			if updateStatusFunc then updateStatusFunc() end
		end
		return
	end

	local animation = Instance.new("Animation")
	animation.AnimationId = animationId

	local animTrack = previewAnimator:LoadAnimation(animation)
	if animTrack then
		previewAnimTrack = animTrack
		previewSettings.AnimationDuration = animTrack.Length or 2
		if statusText then
			statusText.Text = "Animation loaded: " .. string.format("%.2f", previewSettings.AnimationDuration) .. "s"
			task.wait(1.5)
			if updateStatusFunc then updateStatusFunc() end
		end
	else
		if statusText then
			statusText.Text = "Failed to load animation"
			task.wait(1.5)
			if updateStatusFunc then updateStatusFunc() end
		end
	end
end

local function playPreviewAnimation()
	if not previewAnimTrack then
		if statusText then
			statusText.Text = "Load an animation first!"
			task.wait(1.5)
			if updateStatusFunc then updateStatusFunc() end
		end
		return
	end

	if previewPlaying then
		previewAnimTrack:Stop()
		previewPlaying = false
		if previewConnection then
			previewConnection:Disconnect()
			previewConnection = nil
		end
		if statusText then
			statusText.Text = "Preview paused"
			task.wait(1)
			if updateStatusFunc then updateStatusFunc() end
		end
		return
	end

	previewAnimTrack:Play(0, 1, previewSettings.PlaybackSpeed)
	previewPlaying = true

	if statusText then
		statusText.Text = "Preview playing..."
	end

	local startTime = tick()
	previewConnection = game:GetService("RunService").RenderStepped:Connect(function()
		local elapsed = tick() - startTime
		if elapsed >= previewSettings.AnimationDuration then
			previewAnimTrack:Stop()
			previewPlaying = false
			previewConnection:Disconnect()
			previewConnection = nil
			if statusText then
				statusText.Text = "Preview finished"
				task.wait(1)
				if updateStatusFunc then updateStatusFunc() end
			end
		end
		previewSettings.CurrentTime = elapsed
	end)
end

local function stopPreviewAnimation()
	if previewAnimTrack then
		previewAnimTrack:Stop()
	end
	if previewConnection then
		previewConnection:Disconnect()
		previewConnection = nil
	end
	previewPlaying = false
	previewSettings.CurrentTime = 0
end

-- ========== CUTSCENE FUNCTIONS ==========
local function applySlowMotion(enable)
	if statusText and enable then
		statusText.Text = "Slow motion (implement in your game)"
		task.wait(0.8)
	end
end

local function applyCameraShake(intensity, duration)
	local camera = workspace.CurrentCamera
	if not camera then return end

	local originalCFrame = camera.CFrame
	local startTime = tick()

	local connection
	connection = game:GetService("RunService").RenderStepped:Connect(function()
		local elapsed = tick() - startTime
		if elapsed >= duration then
			camera.CFrame = originalCFrame
			connection:Disconnect()
			return
		end

		local remaining = 1 - (elapsed / duration)
		local currentIntensity = intensity * remaining
		local offset = Vector3.new(
			math.random(-currentIntensity, currentIntensity) / 10,
			math.random(-currentIntensity, currentIntensity) / 10,
			math.random(-currentIntensity, currentIntensity) / 10
		)
		camera.CFrame = originalCFrame * CFrame.new(offset)
	end)

	table.insert(shakeConnections, connection)

	task.delay(duration + 0.1, function()
		for i, conn in ipairs(shakeConnections) do
			if conn == connection then
				table.remove(shakeConnections, i)
				break
			end
		end
	end)
end

local function applyZoom(zoomAmount, duration)
	local camera = workspace.CurrentCamera
	if not camera then return end

	local originalFieldOfView = camera.FieldOfView
	local targetFOV = originalFieldOfView * (1 - zoomAmount)

	local tweenService = game:GetService("TweenService")
	local tweenInfo = TweenInfo.new(duration, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
	local tween = tweenService:Create(camera, tweenInfo, {FieldOfView = targetFOV})
	tween:Play()

	task.delay(duration, function()
		local returnTween = tweenService:Create(camera, tweenInfo, {FieldOfView = originalFieldOfView})
		returnTween:Play()
	end)
end

-- Dummy character for rotation preview
local rotationDummy = nil

local function createRotationDummy()
	if rotationDummy and rotationDummy.Parent then
		return rotationDummy
	end

	local dummy = Instance.new("Model")
	dummy.Name = "MotionForge_RotationDummy"

	local rootPart = Instance.new("Part")
	rootPart.Name = "HumanoidRootPart"
	rootPart.Size = Vector3.new(2, 1, 1)
	local camera = workspace.CurrentCamera
	if camera then
		rootPart.Position = camera.CFrame.Position + camera.CFrame.LookVector * 15
	else
		rootPart.Position = Vector3.new(0, 5, 0)
	end
	rootPart.Anchored = true
	rootPart.Parent = dummy

	local humanoid = Instance.new("Humanoid")
	humanoid.Parent = dummy

	dummy.Parent = workspace
	rotationDummy = dummy
	return rotationDummy
end

local function destroyRotationDummy()
	if rotationDummy then
		rotationDummy:Destroy()
		rotationDummy = nil
	end
end

-- Apply camera rotation around a target (with angle + speed)
local function applyCameraRotation(target, angle, speed, direction, duration)
	local camera = workspace.CurrentCamera
	if not camera or not target then
		if statusText then
			statusText.Text = "No target found for rotation preview"
			task.wait(1.5)
			if updateStatusFunc then updateStatusFunc() end
		end
		return
	end

	local rootPart = target:FindFirstChild("HumanoidRootPart") or target.PrimaryPart
	if not rootPart then
		if statusText then
			statusText.Text = "Target has no HumanoidRootPart"
			task.wait(1.5)
			if updateStatusFunc then updateStatusFunc() end
		end
		return
	end

	local originalCFrame = camera.CFrame
	local startTime = tick()
	local directionMultiplier = (direction == "clockwise") and 1 or -1

	local connection
	connection = game:GetService("RunService").RenderStepped:Connect(function()
		local elapsed = tick() - startTime
		if elapsed >= duration then
			camera.CFrame = originalCFrame
			connection:Disconnect()
			return
		end

		local progress = elapsed / duration
		local currentAngle = angle * progress * directionMultiplier

		local offset = originalCFrame.Position - rootPart.Position
		local rotatedOffset = CFrame.new(Vector3.new(0, 0, 0)) * CFrame.Angles(0, math.rad(currentAngle), 0)
		local newPosition = rootPart.Position + (rotatedOffset * offset)
		camera.CFrame = CFrame.lookAt(newPosition, rootPart.Position)
	end)

	table.insert(shakeConnections, connection)

	task.delay(duration + 0.1, function()
		for i, conn in ipairs(shakeConnections) do
			if conn == connection then
				table.remove(shakeConnections, i)
				break
			end
		end
	end)
end

local function cleanupCutsceneEffects()
	for _, conn in ipairs(shakeConnections) do
		if conn and conn.Connected then
			conn:Disconnect()
		end
	end
	shakeConnections = {}

	local camera = workspace.CurrentCamera
	if camera and camera.FieldOfView ~= 70 then
		camera.FieldOfView = 70
	end

	destroyRotationDummy()
end

-- ========== LUA CODE EXPORTER ==========
local function generateHitboxModule()
	return [[
-- MotionForge Hitbox System
-- Generated by MotionForge v1.4.1
-- Created by Gorrilla567_h - Free & Open Source

local HitboxSystem = {}

function HitboxSystem.new(character, data)
    local self = setmetatable({}, {__index = HitboxSystem})
    
    self.Character = character
    self.Humanoid = character:FindFirstChild("Humanoid")
    self.RootPart = character:FindFirstChild("HumanoidRootPart")
    self.Damage = data.Damage or 10
    self.Knockback = data.Knockback or 500
    self.Range = data.Range or 8
    self.Duration = data.Duration or 0.2
    self.HitTargets = {}
    
    return self
end

function HitboxSystem:Fire()
    if not self.RootPart then return end
    
    local params = OverlapParams.new()
    params.MaxParts = 50
    params.FilterType = Enum.RaycastFilterType.Blacklist
    params.FilterDescendantsInstances = {self.Character}
    
    local hits = workspace:GetPartsInPart(self.RootPart, params)
    
    for _, hit in ipairs(hits) do
        local humanoid = hit.Parent:FindFirstChild("Humanoid")
        if humanoid and humanoid ~= self.Humanoid then
            if not self.HitTargets[humanoid] then
                self.HitTargets[humanoid] = true
                humanoid:TakeDamage(self.Damage)
                
                local direction = (hit.Position - self.RootPart.Position).Unit
                local knockbackVelocity = direction * self.Knockback
                local bodyVelocity = Instance.new("BodyVelocity")
                bodyVelocity.Velocity = knockbackVelocity
                bodyVelocity.MaxForce = Vector3.new(1, 1, 1) * 10000
                local rootPart = hit.Parent:FindFirstChild("HumanoidRootPart") or hit.Parent.PrimaryPart
                if rootPart then
                    bodyVelocity.Parent = rootPart
                    task.delay(0.2, function()
                        bodyVelocity:Destroy()
                    end)
                end
            end
        end
    end
    
    task.delay(self.Duration, function()
        self:Destroy()
    end)
end

function HitboxSystem:Destroy()
end

return HitboxSystem
]]
end

local function generateMoveCode()
	local timelineStr = "{\n"
	for i, event in ipairs(currentMove.Timeline) do
		timelineStr = timelineStr .. string.format("        {time = %.2f, type = \"%s\", data = {", event.time, event.type)

		if event.type == "Hitbox" then
			timelineStr = timelineStr .. string.format("damage = %s, knockback = %s", event.data.damage or currentMove.Damage, event.data.knockback or currentMove.Knockback)
		elseif event.type == "Sound" then
			timelineStr = timelineStr .. string.format("soundId = \"%s\"", event.data.soundId or "rbxassetid://123456789")
		elseif event.type == "Effect" then
			timelineStr = timelineStr .. string.format("effectType = \"%s\"", event.data.effectType or "BasicExplosion")
		end

		timelineStr = timelineStr .. "}}"
		if i < #currentMove.Timeline then
			timelineStr = timelineStr .. ","
		end
		timelineStr = timelineStr .. "\n"
	end
	timelineStr = timelineStr .. "    }"

	local cutsceneJson = game:GetService("HttpService"):JSONEncode(currentMove.Cutscene)

	return string.format([[
-- MotionForge Exported Move: %s
-- Generated by MotionForge v1.4.1
-- Created by Gorrilla567_h - Free & Open Source
-- Support development: https://paypal.me/Gorrilla567h

local HitboxSystem = require(script.Parent.HitboxSystem)

local Move = {}

Move.Name = "%s"
Move.Cooldown = %s
Move.AnimationId = "%s"
Move.Damage = %s
Move.Knockback = %s
Move.Timeline = %s
Move.Cutscene = %s

function Move.Execute(character, mousePosition)
    local humanoid = character:FindFirstChild("Humanoid")
    if not humanoid then return false end
    
    if Move.LastUsed and tick() - Move.LastUsed < Move.Cooldown then
        return false
    end
    Move.LastUsed = tick()
    
    local animator = humanoid:FindFirstChild("Animator")
    if animator and Move.AnimationId ~= "" then
        local animation = Instance.new("Animation")
        animation.AnimationId = Move.AnimationId
        local animTrack = animator:LoadAnimation(animation)
        animTrack:Play()
    end
    
    local cutsceneApplied = false
    
    for _, event in ipairs(Move.Timeline) do
        task.delay(event.time, function()
            if event.type == "Hitbox" then
                if Move.Cutscene.Enabled and not cutsceneApplied then
                    cutsceneApplied = true
                    
                    if Move.Cutscene.SlowMotion then
                        print("Slow motion would activate here")
                    end
                    
                    if Move.Cutscene.CameraShake then
                        task.delay(0.05, function()
                            local camera = workspace.CurrentCamera
                            if camera then
                                local intensity = Move.Cutscene.ShakeIntensity
                                local duration = Move.Cutscene.Duration
                                local originalCFrame = camera.CFrame
                                local startTime = tick()
                                local connection
                                connection = game:GetService("RunService").RenderStepped:Connect(function()
                                    local elapsed = tick() - startTime
                                    if elapsed >= duration then
                                        camera.CFrame = originalCFrame
                                        connection:Disconnect()
                                        return
                                    end
                                    local remaining = 1 - (elapsed / duration)
                                    local currentIntensity = intensity * remaining
                                    local offset = Vector3.new(
                                        math.random(-currentIntensity, currentIntensity) / 10,
                                        math.random(-currentIntensity, currentIntensity) / 10,
                                        math.random(-currentIntensity, currentIntensity) / 10
                                    )
                                    camera.CFrame = originalCFrame * CFrame.new(offset)
                                end)
                            end
                        end)
                    end
                    
                    if Move.Cutscene.Zoom then
                        task.delay(0.05, function()
                            local camera = workspace.CurrentCamera
                            if camera then
                                local originalFOV = camera.FieldOfView
                                local targetFOV = originalFOV * (1 - Move.Cutscene.ZoomAmount)
                                local tweenService = game:GetService("TweenService")
                                local tweenInfo = TweenInfo.new(Move.Cutscene.Duration, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
                                local tween = tweenService:Create(camera, tweenInfo, {FieldOfView = targetFOV})
                                tween:Play()
                                task.delay(Move.Cutscene.Duration, function()
                                    local returnTween = tweenService:Create(camera, tweenInfo, {FieldOfView = originalFOV})
                                    returnTween:Play()
                                end)
                            end
                        end)
                    end
                    
                    if Move.Cutscene.CameraRotate then
                        task.delay(0.05, function()
                            local camera = workspace.CurrentCamera
                            if camera and character then
                                local rootPart = character:FindFirstChild("HumanoidRootPart")
                                if rootPart then
                                    local originalCFrame = camera.CFrame
                                    local angle = Move.Cutscene.RotationAngle
                                    local speed = Move.Cutscene.RotationSpeed
                                    local duration = Move.Cutscene.Duration
                                    local dirMultiplier = (Move.Cutscene.RotationDirection == "clockwise") and 1 or -1
                                    local startTime = tick()
                                    local connection
                                    connection = game:GetService("RunService").RenderStepped:Connect(function()
                                        local elapsed = tick() - startTime
                                        if elapsed >= duration then
                                            camera.CFrame = originalCFrame
                                            connection:Disconnect()
                                            return
                                        end
                                        local progress = elapsed / duration
                                        local currentAngle = angle * progress * dirMultiplier
                                        local offset = originalCFrame.Position - rootPart.Position
                                        local rotatedOffset = CFrame.new(Vector3.new(0, 0, 0)) * CFrame.Angles(0, math.rad(currentAngle), 0)
                                        local newPosition = rootPart.Position + (rotatedOffset * offset)
                                        camera.CFrame = CFrame.lookAt(newPosition, rootPart.Position)
                                    end)
                                end
                            end
                        end)
                    end
                end
                
                local hitbox = HitboxSystem.new(character, {
                    Damage = event.data.damage or Move.Damage,
                    Knockback = event.data.knockback or Move.Knockback,
                    Range = 8
                })
                hitbox:Fire()
            elseif event.type == "Sound" then
                local sound = Instance.new("Sound")
                sound.SoundId = event.data.soundId
                sound.Parent = character
                sound:Play()
                task.delay(sound.TimeLength or 2, function()
                    sound:Destroy()
                end)
            elseif event.type == "Effect" then
                local part = Instance.new("Part")
                part.Size = Vector3.new(2, 2, 2)
                part.Anchored = true
                part.CanCollide = false
                part.BrickColor = BrickColor.new("Bright red")
                part.Material = Enum.Material.Neon
                part.Position = character.HumanoidRootPart.Position
                part.Parent = workspace
                task.delay(0.5, function()
                    part:Destroy()
                end)
            end
        end)
    end
    
    return true
end

return Move
]], currentMove.Name, currentMove.Name, currentMove.Cooldown, currentMove.AnimId, currentMove.Damage, currentMove.Knockback, timelineStr, cutsceneJson)
end

local function exportToClipboard()
	if #currentMove.Timeline == 0 then
		if statusText then
			statusText.Text = "Add at least one event before exporting!"
			task.wait(1.5)
			if updateStatusFunc then updateStatusFunc() end
		end
		return
	end

	local code = generateMoveCode()

	local clipboardSuccess = pcall(function()
		setclipboard(code)
	end)

	if not clipboardSuccess then
		local dialog = Instance.new("Frame")
		dialog.Size = UDim2.new(0, 500, 0, 400)
		dialog.Position = UDim2.new(0.5, -250, 0.5, -200)
		dialog.BackgroundColor3 = Color3.fromRGB(35, 35, 40)
		dialog.BorderSizePixel = 0
		dialog.Parent = mainGui

		local dialogCorner = Instance.new("UICorner")
		dialogCorner.CornerRadius = UDim.new(0, 10)
		dialogCorner.Parent = dialog

		local title = Instance.new("TextLabel")
		title.Text = "Exported Code - Select and Copy (Ctrl+C)"
		title.TextColor3 = Color3.fromRGB(255, 255, 255)
		title.TextSize = 14
		title.Font = Enum.Font.GothamSemibold
		title.BackgroundTransparency = 1
		title.Size = UDim2.new(1, 0, 0, 40)
		title.Parent = dialog

		local textBox = Instance.new("TextBox")
		textBox.Text = code
		textBox.TextColor3 = Color3.fromRGB(200, 200, 200)
		textBox.TextSize = 11
		textBox.Font = Enum.Font.Code
		textBox.TextXAlignment = Enum.TextXAlignment.Left
		textBox.TextYAlignment = Enum.TextYAlignment.Top
		textBox.BackgroundColor3 = Color3.fromRGB(25, 25, 30)
		textBox.BorderSizePixel = 0
		textBox.Size = UDim2.new(1, -20, 1, -80)
		textBox.Position = UDim2.new(0, 10, 0, 50)
		textBox.ClearTextOnFocus = false
		textBox.MultiLine = true
		textBox.Parent = dialog

		local textCorner = Instance.new("UICorner")
		textCorner.CornerRadius = UDim.new(0, 8)
		textCorner.Parent = textBox

		local closeBtn = Instance.new("TextButton")
		closeBtn.Text = "Close"
		closeBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
		closeBtn.TextSize = 12
		closeBtn.BackgroundColor3 = Color3.fromRGB(0, 120, 215)
		closeBtn.BorderSizePixel = 0
		closeBtn.Size = UDim2.new(0, 100, 0, 36)
		closeBtn.Position = UDim2.new(1, -120, 1, -50)
		closeBtn.Parent = dialog

		local closeCorner = Instance.new("UICorner")
		closeCorner.CornerRadius = UDim.new(0, 6)
		closeCorner.Parent = closeBtn

		closeBtn.MouseButton1Click:Connect(function()
			dialog:Destroy()
		end)

		textBox:CaptureFocus()

		if statusText then
			statusText.Text = "Code shown in dialog - Select and copy"
			task.wait(2)
			if updateStatusFunc then updateStatusFunc() end
		end
	else
		if statusText then
			statusText.Text = "Copied to clipboard!"
			task.wait(1.5)
			if updateStatusFunc then updateStatusFunc() end
		end
	end
end

local function exportToGame()
	if #currentMove.Timeline == 0 then
		if statusText then
			statusText.Text = "Add at least one event before exporting!"
			task.wait(1.5)
			if updateStatusFunc then updateStatusFunc() end
		end
		return
	end

	local folder = game.ReplicatedStorage:FindFirstChild("MotionForge_Moves")
	if not folder then
		folder = Instance.new("Folder")
		folder.Name = "MotionForge_Moves"
		folder.Parent = game.ReplicatedStorage
	end

	local hitboxModule = game.ReplicatedStorage:FindFirstChild("HitboxSystem")
	if not hitboxModule then
		hitboxModule = Instance.new("ModuleScript")
		hitboxModule.Name = "HitboxSystem"
		hitboxModule.Source = generateHitboxModule()
		hitboxModule.Parent = game.ReplicatedStorage
	end

	local moveName = string.gsub(currentMove.Name, "[^%w]", "_")
	local moveModule = Instance.new("ModuleScript")
	moveModule.Name = moveName
	moveModule.Source = generateMoveCode()
	moveModule.Parent = folder

	if statusText then
		statusText.Text = "Exported to ReplicatedStorage!"
		task.wait(1.5)
		if updateStatusFunc then updateStatusFunc() end
	end
end

-- ========== SAVE/LOAD FUNCTIONS ==========
local SAVE_PREFIX = "MotionForge_Move_"

local function getSavedMoveNames()
	local indexData = plugin:GetSetting("MotionForge_SavedMoves")
	if indexData and indexData ~= "" then
		local success, decoded = pcall(function()
			return game:GetService("HttpService"):JSONDecode(indexData)
		end)
		if success and decoded then
			return decoded
		end
	end
	return {}
end

local function saveMoveNameList(names)
	pcall(function()
		plugin:SetSetting("MotionForge_SavedMoves", game:GetService("HttpService"):JSONEncode(names))
	end)
end

local function saveCurrentMove()
	local moveName = currentMove.Name
	if not moveName or moveName == "" then
		moveName = "Unnamed Move"
	end

	local cleanName = string.gsub(moveName, "[^%w%-_]", "_")
	local settingKey = SAVE_PREFIX .. cleanName

	local moveData = {
		Name = currentMove.Name,
		Cooldown = currentMove.Cooldown,
		AnimId = currentMove.AnimId,
		Damage = currentMove.Damage,
		Knockback = currentMove.Knockback,
		Timeline = currentMove.Timeline,
		Cutscene = currentMove.Cutscene,
		Version = "1.4.1"
	}

	local success = pcall(function()
		plugin:SetSetting(settingKey, game:GetService("HttpService"):JSONEncode(moveData))
	end)

	if success then
		local savedNames = getSavedMoveNames()
		local found = false
		for _, name in ipairs(savedNames) do
			if name == moveName then
				found = true
				break
			end
		end
		if not found then
			table.insert(savedNames, moveName)
			saveMoveNameList(savedNames)
		end
		if statusText then
			statusText.Text = "Saved: " .. moveName
			task.wait(1.5)
			if updateStatusFunc then updateStatusFunc() end
		end
		if refreshMoveListFunc then refreshMoveListFunc() end
		return true
	else
		if statusText then statusText.Text = "Save failed!" end
		return false
	end
end

local function loadMoveByName(moveName)
	local cleanName = string.gsub(moveName, "[^%w%-_]", "_")
	local settingKey = SAVE_PREFIX .. cleanName
	local moveData = plugin:GetSetting(settingKey)

	if not moveData or moveData == "" then
		if statusText then statusText.Text = "Move not found" end
		return false
	end

	local success, data = pcall(function()
		return game:GetService("HttpService"):JSONDecode(moveData)
	end)

	if success and data then
		currentMove.Name = data.Name or "New Move"
		currentMove.Cooldown = data.Cooldown or "2"
		currentMove.AnimId = data.AnimId or ""
		currentMove.Damage = data.Damage or "15"
		currentMove.Knockback = data.Knockback or "500"
		currentMove.Timeline = data.Timeline or {}
		currentMove.Cutscene = data.Cutscene or currentMove.Cutscene

		if nameInput then nameInput.Text = currentMove.Name end
		if cooldownInput then cooldownInput.Text = currentMove.Cooldown end
		if animInput then animInput.Text = currentMove.AnimId end
		if damageInput then damageInput.Text = currentMove.Damage end
		if knockbackInput then knockbackInput.Text = currentMove.Knockback end

		mainGui.Title = "MotionForge - " .. currentMove.Name
		if refreshEventListFunc then refreshEventListFunc() end
		if updateStatusFunc then updateStatusFunc() end
		if visualizerActive and type(updateHitboxVisualizer) == "function" then
			updateHitboxVisualizer()
		end
		if statusText then
			statusText.Text = "Loaded: " .. moveName
			task.wait(1.5)
			if updateStatusFunc then updateStatusFunc() end
		end
		return true
	end
	return false
end

local function deleteMoveByName(moveName)
	local cleanName = string.gsub(moveName, "[^%w%-_]", "_")
	local settingKey = SAVE_PREFIX .. cleanName
	plugin:SetSetting(settingKey, nil)

	local savedNames = getSavedMoveNames()
	local newNames = {}
	for _, name in ipairs(savedNames) do
		if name ~= moveName then
			table.insert(newNames, name)
		end
	end
	saveMoveNameList(newNames)

	if statusText then
		statusText.Text = "Deleted: " .. moveName
		task.wait(1.5)
		if updateStatusFunc then updateStatusFunc() end
	end
	if refreshMoveListFunc then refreshMoveListFunc() end
	return true
end

