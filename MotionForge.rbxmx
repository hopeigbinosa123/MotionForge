	end)
end

supportButton.MouseButton1Click:Connect(showSupportDialog)

function updateStatusFunc()
	if statusText then
		local eventCount = #currentMove.Timeline
		statusText.Text = string.format("Editing: %s | Dmg: %s | CD: %ss | Events: %d", currentMove.Name, currentMove.Damage, currentMove.Cooldown, eventCount)
	end
end

updateStatusFunc()

-- ========== WELCOME MESSAGE (First Time) ==========
local hasSeenWelcome = plugin:GetSetting("MotionForge_WelcomeSeen")
if not hasSeenWelcome or hasSeenWelcome == "" then
	task.delay(0.5, function()
		local welcomeDialog = Instance.new("Frame")
		welcomeDialog.Size = UDim2.new(0, 400, 0, 300)
		welcomeDialog.Position = UDim2.new(0.5, -200, 0.5, -150)
		welcomeDialog.BackgroundColor3 = Color3.fromRGB(35, 35, 40)
		welcomeDialog.BorderSizePixel = 0
		welcomeDialog.Parent = mainGui

		local welcomeCorner = Instance.new("UICorner")
		welcomeCorner.CornerRadius = UDim.new(0, 12)
		welcomeCorner.Parent = welcomeDialog

		local title = Instance.new("TextLabel")
		title.Text = "⚡ Welcome to MotionForge!"
		title.TextColor3 = Color3.fromRGB(255, 255, 255)
		title.TextSize = 18
		title.Font = Enum.Font.GothamBold
		title.BackgroundTransparency = 1
		title.Size = UDim2.new(1, 0, 0, 50)
		title.Parent = welcomeDialog

		local tips = Instance.new("TextLabel")
		tips.Text = "Quick Tips:\n\n• Create a move by setting Name, Damage, and Cooldown\n• Click '+ Add Event' to add hitboxes at specific times\n• Click '👁️ Show Hitbox Preview' to see your hitbox\n• Use '📦 Export' to get Lua code for your game\n• Save your moves to use them later\n• Check out the Template Library for examples"
		tips.TextColor3 = Color3.fromRGB(160, 160, 170)
		tips.TextSize = 11
		tips.Font = Enum.Font.Gotham
		tips.TextXAlignment = Enum.TextXAlignment.Left
		tips.TextYAlignment = Enum.TextYAlignment.Top
		tips.BackgroundTransparency = 1
		tips.Size = UDim2.new(1, -20, 1, -100)
		tips.Position = UDim2.new(0, 10, 0, 55)
		tips.Parent = welcomeDialog

		local gotItBtn = Instance.new("TextButton")
		gotItBtn.Text = "Got it!"
		gotItBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
		gotItBtn.TextSize = 13
		gotItBtn.Font = Enum.Font.GothamSemibold
		gotItBtn.BackgroundColor3 = Color3.fromRGB(0, 120, 215)
		gotItBtn.BorderSizePixel = 0
		gotItBtn.Size = UDim2.new(0, 120, 0, 36)
		gotItBtn.Position = UDim2.new(0.5, -60, 1, -55)
		gotItBtn.Parent = welcomeDialog

		local gotItCorner = Instance.new("UICorner")
		gotItCorner.CornerRadius = UDim.new(0, 8)
		gotItCorner.Parent = gotItBtn

		gotItBtn.MouseButton1Click:Connect(function()
			welcomeDialog:Destroy()
			plugin:SetSetting("MotionForge_WelcomeSeen", "true")
		end)
	end)
end

mainGui:GetPropertyChangedSignal("Enabled"):Connect(function()
	if not mainGui.Enabled then
		clearPreview()
		cleanupCutsceneEffects()
		destroyRotationDummy()
		stopPreviewAnimation()
		destroyPreviewDummy()
	end
end)

task.defer(function()
	contentLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Wait()
	scrollFrame.CanvasSize = UDim2.new(0, 0, 0, contentLayout.AbsoluteContentSize.Y + 16)
	scrollContent.Size = UDim2.new(1, 0, 0, contentLayout.AbsoluteContentSize.Y)
end)

mainGui.Enabled = true

button.Click:Connect(function()
	mainGui.Enabled = not mainGui.Enabled
end)

