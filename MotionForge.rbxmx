local refreshButtonCorner = Instance.new("UICorner")
refreshButtonCorner.CornerRadius = UDim.new(0, 6)
refreshButtonCorner.Parent = refreshButton

refreshButton.MouseButton1Click:Connect(function()
	refreshMoveListFunc()
	if statusText then
		statusText.Text = "List refreshed"
		task.wait(1)
		if updateStatusFunc then updateStatusFunc() end
	end
end)

refreshMoveListFunc()

