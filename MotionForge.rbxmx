local speedPresets = {60, 120, 180, 240, 360, 480, 720}
local speedX = 250
for _, spd in ipairs(speedPresets) do
	local presetBtn = Instance.new("TextButton")
	presetBtn.Text = tostring(spd)
	presetBtn.TextColor3 = Color3.fromRGB(200, 200, 200)
	presetBtn.TextSize = 10
	presetBtn.Font = Enum.Font.Gotham
	presetBtn.BackgroundColor3 = Color3.fromRGB(45, 45, 50)
	presetBtn.BorderSizePixel = 0
	presetBtn.Size = UDim2.new(0, 40, 0, 24)
	presetBtn.Position = UDim2.new(0, speedX, 0, 2)
	presetBtn.Parent = rotationSpeedRow

	local presetCorner = Instance.new("UICorner")
	presetCorner.CornerRadius = UDim.new(0, 6)
	presetCorner.Parent = presetBtn

	presetBtn.MouseButton1Click:Connect(function()
		currentMove.Cutscene.RotationSpeed = spd
		rotationSpeedValue.Text = tostring(spd)
		updateDurationInfo()
	end)

	speedX = speedX + 45
end

-- Duration info display
local durationInfo = Instance.new("TextLabel")
durationInfo.Name = "DurationInfo"
durationInfo.TextColor3 = Color3.fromRGB(100, 100, 110)
durationInfo.TextSize = 10
durationInfo.Font = Enum.Font.Gotham
durationInfo.BackgroundTransparency = 1
durationInfo.Size = UDim2.new(0, 150, 0, 20)
durationInfo.Position = UDim2.new(1, -160, 0, 50)
durationInfo.Parent = rotationSpeedRow

local function updateDurationInfo()
	local angle = currentMove.Cutscene.RotationAngle
	local speed = currentMove.Cutscene.RotationSpeed
	if speed > 0 then
		durationInfo.Text = "⏱️ Duration: " .. string.format("%.2f", angle / speed) .. "s"
	else
		durationInfo.Text = "⏱️ Duration: ∞ (speed = 0)"
	end
end
updateDurationInfo()

