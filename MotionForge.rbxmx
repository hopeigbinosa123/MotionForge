cutsceneInfo.TextSize = 10
cutsceneInfo.Font = Enum.Font.Gotham
cutsceneInfo.TextXAlignment = Enum.TextXAlignment.Center
cutsceneInfo.BackgroundTransparency = 1
cutsceneInfo.Size = UDim2.new(1, 0, 0, 40)
cutsceneInfo.Position = UDim2.new(0, 0, 0, 565)
cutsceneInfo.Parent = cutsceneCard

local previewCutsceneButton = Instance.new("TextButton")
previewCutsceneButton.Text = "🎬 Preview Cutscene"
previewCutsceneButton.TextColor3 = Color3.fromRGB(255, 255, 255)
previewCutsceneButton.TextSize = 12
previewCutsceneButton.Font = Enum.Font.Gotham
previewCutsceneButton.BackgroundColor3 = Color3.fromRGB(100, 100, 120)
previewCutsceneButton.BorderSizePixel = 0
previewCutsceneButton.Size = UDim2.new(1, 0, 0, 32)
previewCutsceneButton.Position = UDim2.new(0, 0, 0, 615)
previewCutsceneButton.Parent = cutsceneCard

local previewCorner = Instance.new("UICorner")
previewCorner.CornerRadius = UDim.new(0, 8)
previewCorner.Parent = previewCutsceneButton

previewCutsceneButton.MouseButton1Click:Connect(function()
	if not currentMove.Cutscene.Enabled then
		if statusText then
			statusText.Text = "Enable cutscene first!"
			task.wait(1.5)
			if updateStatusFunc then updateStatusFunc() end
		end
		return
	end

	if statusText then
		statusText.Text = "Previewing cutscene effects..."
		task.wait(0.5)
	end

	local target = nil
	local player = game.Players.LocalPlayer
	local character = player and player.Character

	if character and character.Parent then
		target = character
		if statusText then
			statusText.Text = "Using your character for rotation"
		end
	else
		target = createRotationDummy()
		if statusText then
			statusText.Text = "Created dummy character for rotation"
		end
	end

	if currentMove.Cutscene.SlowMotion then
		applySlowMotion(true)
		task.delay(currentMove.Cutscene.Duration, function()
			applySlowMotion(false)
		end)
	end

	if currentMove.Cutscene.CameraShake then
		applyCameraShake(currentMove.Cutscene.ShakeIntensity, currentMove.Cutscene.Duration)
	end

	if currentMove.Cutscene.Zoom then
		applyZoom(currentMove.Cutscene.ZoomAmount, currentMove.Cutscene.Duration)
	end

	if currentMove.Cutscene.CameraRotate and target then
		local angle = currentMove.Cutscene.RotationAngle
		local speed = currentMove.Cutscene.RotationSpeed
		if speed > 0 then
			local duration = angle / speed
			applyCameraRotation(
				target,
				angle,
				speed,
				currentMove.Cutscene.RotationDirection,
				duration
			)
			if statusText then
				statusText.Text = "Rotation: " .. angle .. "° at " .. speed .. "°/s (" .. string.format("%.2f", duration) .. "s)"
			end
		else
			if statusText then
				statusText.Text = "Rotation speed must be greater than 0"
			end
		end
	elseif currentMove.Cutscene.CameraRotate and not target then
		if statusText then
			statusText.Text = "Could not create target for rotation"
		end
	end

	if statusText then
		task.wait(currentMove.Cutscene.Duration + 0.5)
		statusText.Text = "Preview finished"
		task.wait(1)
		if updateStatusFunc then updateStatusFunc() end
	end
end)

-- ========== CARD 7: TEMPLATE LIBRARY ==========
local templateCard = createCard("📚 Template Library", 7)

local searchBox = Instance.new("TextBox")
searchBox.PlaceholderText = "Search templates..."
searchBox.Text = ""
