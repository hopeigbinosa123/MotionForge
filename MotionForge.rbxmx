local function showEventTypeMenu()
	local menuFrame = Instance.new("Frame")
	menuFrame.Size = UDim2.new(0, 200, 0, 150)
	menuFrame.Position = UDim2.new(0.5, -100, 0.5, -75)
	menuFrame.BackgroundColor3 = Color3.fromRGB(35, 35, 40)
	menuFrame.BorderSizePixel = 0
	menuFrame.Parent = mainGui

	local menuCorner = Instance.new("UICorner")
	menuCorner.CornerRadius = UDim.new(0, 10)
	menuCorner.Parent = menuFrame

	local title = Instance.new("TextLabel")
	title.Text = "Select Event Type"
	title.TextColor3 = Color3.fromRGB(255, 255, 255)
	title.TextSize = 14
	title.Font = Enum.Font.GothamSemibold
	title.BackgroundTransparency = 1
	title.Size = UDim2.new(1, 0, 0, 40)
	title.Parent = menuFrame

	local hitboxBtn = Instance.new("TextButton")
	hitboxBtn.Text = "🔴 Hitbox (Damage)"
	hitboxBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
	hitboxBtn.TextSize = 12
	hitboxBtn.BackgroundColor3 = Color3.fromRGB(60, 60, 70)
	hitboxBtn.BorderSizePixel = 0
	hitboxBtn.Size = UDim2.new(1, -20, 0, 36)
	hitboxBtn.Position = UDim2.new(0, 10, 0, 45)
	hitboxBtn.Parent = menuFrame

	local btnCorner = Instance.new("UICorner")
	btnCorner.CornerRadius = UDim.new(0, 6)
	btnCorner.Parent = hitboxBtn

	local soundBtn = Instance.new("TextButton")
	soundBtn.Text = "🔊 Sound Effect"
	soundBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
	soundBtn.TextSize = 12
	soundBtn.BackgroundColor3 = Color3.fromRGB(60, 60, 70)
	soundBtn.BorderSizePixel = 0
	soundBtn.Size = UDim2.new(1, -20, 0, 36)
	soundBtn.Position = UDim2.new(0, 10, 0, 90)
	soundBtn.Parent = menuFrame

	local soundCorner = Instance.new("UICorner")
	soundCorner.CornerRadius = UDim.new(0, 6)
	soundCorner.Parent = soundBtn

	local effectBtn = Instance.new("TextButton")
	effectBtn.Text = "✨ Visual Effect"
	effectBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
	effectBtn.TextSize = 12
	effectBtn.BackgroundColor3 = Color3.fromRGB(60, 60, 70)
	effectBtn.BorderSizePixel = 0
	effectBtn.Size = UDim2.new(1, -20, 0, 36)
	effectBtn.Position = UDim2.new(0, 10, 0, 135)
	effectBtn.Parent = menuFrame

	local effectCorner = Instance.new("UICorner")
	effectCorner.CornerRadius = UDim.new(0, 6)
	effectCorner.Parent = effectBtn

	local function closeMenu()
		menuFrame:Destroy()
	end

	hitboxBtn.MouseButton1Click:Connect(function()
		closeMenu()
		local newTime = #currentMove.Timeline * 0.3 + 0.3
		addEvent("Hitbox", newTime, {damage = currentMove.Damage, knockback = currentMove.Knockback})
		refreshEventListFunc()
		if updateStatusFunc then updateStatusFunc() end
		if visualizerActive and type(updateHitboxVisualizer) == "function" then
			updateHitboxVisualizer()
		end
		if statusText then
			statusText.Text = "Added hitbox at " .. string.format("%.2f", newTime) .. "s"
			task.wait(1.5)
			if updateStatusFunc then updateStatusFunc() end
		end
	end)

	soundBtn.MouseButton1Click:Connect(function()
		closeMenu()
		local newTime = #currentMove.Timeline * 0.3 + 0.3
		addEvent("Sound", newTime, {soundId = "rbxassetid://123456789"})
		refreshEventListFunc()
		if updateStatusFunc then updateStatusFunc() end
		if statusText then
			statusText.Text = "Added sound at " .. string.format("%.2f", newTime) .. "s"
			task.wait(1.5)
			if updateStatusFunc then updateStatusFunc() end
		end
	end)

	effectBtn.MouseButton1Click:Connect(function()
		closeMenu()
		local newTime = #currentMove.Timeline * 0.3 + 0.3
		addEvent("Effect", newTime, {effectType = "Basic Explosion"})
		refreshEventListFunc()
		if updateStatusFunc then updateStatusFunc() end
		if statusText then
			statusText.Text = "Added effect at " .. string.format("%.2f", newTime) .. "s"
			task.wait(1.5)
			if updateStatusFunc then updateStatusFunc() end
		end
	end)
end

