	currentMove.Name = val
	mainGui.Title = "MotionForge - " .. val
	if updateStatusFunc then updateStatusFunc() end
end, 40)
nameInput = nameInputTemp

local cooldownRow, cooldownInputTemp = createRow(infoCard, "Cooldown (sec)", currentMove.Cooldown, function(val)
	currentMove.Cooldown = val
	if updateStatusFunc then updateStatusFunc() end
end, 80)
cooldownInput = cooldownInputTemp

-- CARD 2: ANIMATION
