moveListCorner.CornerRadius = UDim.new(0, 6)
moveListCorner.Parent = moveListBox

local moveListLayout = Instance.new("UIListLayout")
moveListLayout.Padding = UDim.new(0, 4)
moveListLayout.SortOrder = Enum.SortOrder.LayoutOrder
moveListLayout.Parent = moveListBox

function refreshMoveListFunc()
	local childrenToRemove = {}
	for _, child in ipairs(moveListBox:GetChildren()) do
		if child:IsA("TextButton") or child:IsA("TextLabel") then
			table.insert(childrenToRemove, child)
		end
	end
	for _, child in ipairs(childrenToRemove) do
		child:Destroy()
	end

	local savedNames = getSavedMoveNames()

	if #savedNames == 0 then
		local emptyLabel = Instance.new("TextLabel")
		emptyLabel.Name = "EmptyLabel"
		emptyLabel.Text = "No saved moves"
		emptyLabel.TextColor3 = Color3.fromRGB(100, 100, 110)
		emptyLabel.TextSize = 12
		emptyLabel.BackgroundTransparency = 1
		emptyLabel.Size = UDim2.new(1, 0, 0, 30)
		emptyLabel.Parent = moveListBox
	else
		for _, moveName in ipairs(savedNames) do
			local moveButton = Instance.new("TextButton")
			moveButton.Name = "MoveButton_" .. string.gsub(moveName, "[^%w]", "_")
			moveButton.Text = "📁 " .. moveName
			moveButton.TextColor3 = Color3.fromRGB(200, 200, 200)
			moveButton.TextSize = 12
			moveButton.TextXAlignment = Enum.TextXAlignment.Left
			moveButton.BackgroundColor3 = Color3.fromRGB(50, 50, 55)
			moveButton.BorderSizePixel = 0
			moveButton.Size = UDim2.new(1, -10, 0, 32)
			moveButton.Parent = moveListBox

			local btnCorner = Instance.new("UICorner")
			btnCorner.CornerRadius = UDim.new(0, 4)
			btnCorner.Parent = moveButton

			moveButton.MouseButton1Click:Connect(function()
				loadMoveByName(moveName)
			end)

			moveButton.MouseButton2Click:Connect(function()
				deleteMoveByName(moveName)
			end)
		end
	end

	task.defer(function()
		moveListBox.CanvasSize = UDim2.new(0, 0, 0, moveListLayout.AbsoluteContentSize.Y + 10)
	end)
end

local refreshButton = Instance.new("TextButton")
